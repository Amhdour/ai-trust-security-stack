# SECURITY NOTE: development placeholders only; replace before running.
# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# Vault (dev only)
VAULT_DEV_ROOT_TOKEN_ID=dev-root-token

# Langfuse
LANGFUSE_DATABASE_URL=postgresql://langfuse:langfuse@db:5432/langfuse
LANGFUSE_POSTGRES_DB=langfuse
LANGFUSE_POSTGRES_USER=langfuse
LANGFUSE_POSTGRES_PASSWORD=langfuse
LANGFUSE_NEXTAUTH_SECRET=langfuse-nextauth-dev-secret
LANGFUSE_SALT=langfuse-dev-salt
LANGFUSE_NEXTAUTH_URL=https://your-codespace-name-3002.app.github.dev
LANGFUSE_INIT_ORG_ID=org-codespaces
LANGFUSE_INIT_ORG_NAME=Codespaces Org
LANGFUSE_INIT_PROJECT_ID=proj-onyx
LANGFUSE_INIT_PROJECT_NAME=Onyx Traces
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-onyx-codespaces
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-onyx-codespaces
LANGFUSE_INIT_USER_EMAIL=admin@codespaces.local
LANGFUSE_INIT_USER_NAME=Codespaces Admin
LANGFUSE_INIT_USER_PASSWORD=change-me

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# Superset
SUPERSET_SECRET_KEY=replace-me
