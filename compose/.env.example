# SECURITY NOTE: development placeholders only; replace before running.
# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# Vault (dev only)
VAULT_DEV_ROOT_TOKEN_ID=dev-root-token

# Langfuse
LANGFUSE_DATABASE_URL=postgresql://langfuse:langfuse@db:5432/langfuse
LANGFUSE_NEXTAUTH_SECRET=replace-me
LANGFUSE_SALT=replace-me
LANGFUSE_NEXTAUTH_URL=http://localhost:3000

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# Superset
SUPERSET_SECRET_KEY=replace-me
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=change-me
